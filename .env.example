# =========================================================
# naffAI — sales tracker for a phone retail call-center
# Copy to .env and adjust before running `docker compose up`
# =========================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-50+chars-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:8000
DJANGO_TIME_ZONE=Asia/Tashkent
DJANGO_LANGUAGE_CODE=ru

# --- Database (PostgreSQL) ---
POSTGRES_DB=naffai
POSTGRES_USER=naffai
POSTGRES_PASSWORD=naffai
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- CORS / Frontend origin ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Superuser bootstrap (used by entrypoint on first run) ---
DJANGO_SUPERUSER_USERNAME=dostik
DJANGO_SUPERUSER_PASSWORD=tostik
DJANGO_SUPERUSER_EMAIL=dostik@example.com

# --- Payroll defaults ---
PAYROLL_DEFAULT_THRESHOLD_UZS=50000000
PAYROLL_DEFAULT_PAYOUT_TYPE=percent     # fixed | percent | tiers
PAYROLL_DEFAULT_PAYOUT_VALUE=3.0        # for percent — 3.0 = 3% above threshold

# --- IMEI online lookup (optional) ---
IMEI_ONLINE_LOOKUP_ENABLED=0
IMEI_ONLINE_API_URL=https://alpha.imeicheck.com/api/modelBrandName
IMEI_ONLINE_API_KEY=

# --- Telegram bot (optional, phase 5) ---
TELEGRAM_BOT_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=
TELEGRAM_API_BASE=http://web:8000

# --- Frontend (Vite reads VITE_ prefixed vars) ---
VITE_API_BASE_URL=http://localhost:8000/api
